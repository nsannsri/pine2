//@version=5
indicator("Multi RSI (9 Lengths)", shorttitle="Multi RSI", overlay=false)

src = input.source(close, "Source")

rsi3   = ta.rsi(src, 3)
rsi7   = ta.rsi(src, 7)
rsi14  = ta.rsi(src, 14)
rsi28  = ta.rsi(src, 28)
rsi50  = ta.rsi(src, 50)
rsi100 = ta.rsi(src, 100)
rsi150 = ta.rsi(src, 150)
rsi200 = ta.rsi(src, 200)
rsi250 = ta.rsi(src, 250)

plot(rsi3,   "RSI 3",   color=color.red,    linewidth=1)
plot(rsi7,   "RSI 7",   color=color.orange, linewidth=1)
plot(rsi14,  "RSI 14",  color=color.yellow, linewidth=1)
plot(rsi28,  "RSI 28",  color=color.lime,   linewidth=1)
plot(rsi50,  "RSI 50",  color=color.teal,   linewidth=1)
plot(rsi100, "RSI 100", color=color.aqua,   linewidth=1)
plot(rsi150, "RSI 150", color=color.blue,   linewidth=1)
plot(rsi200, "RSI 200", color=color.purple, linewidth=1)
plot(rsi250, "RSI 250", color=color.fuchsia,linewidth=1)

hline(70, "OB", color=color.new(color.red,   60), linestyle=hline.style_dashed)
hline(50, "Mid",color=color.new(color.gray,  60), linestyle=hline.style_dotted)
hline(30, "OS", color=color.new(color.green, 60), linestyle=hline.style_dashed)

//@version=5
indicator('SAN-RSI Momentum Trend', overlay=true)


// ** ---> Inputs ------------- {
var bool positive       = false
var bool negative       = false
string RSI_group        = "RSI Settings"
string visual           = "Visuals"
int Len2                = input(14,"RSI 1️⃣",inline = "rsi",group = RSI_group)
int pmom                = input(65," Positive above",inline = "rsi1",group = RSI_group)
int nmom                = input(35,"Negative below",inline = "rsi1",group = RSI_group)
bool showlabels         = input(true,"Show Signals ❓",inline = "001",group = visual)
color p                 = input(color.rgb(76, 175, 79),"Buy",inline = "001",group = visual)
color n                 = input(color.rgb(255, 82, 82),"Sell",inline = "001",group = visual)
int confirmBars         = input(3, "Confirm within N candles", group = visual)
rsi                     = ta.rsi(close, Len2)
//------------------- }

// ** ---> Momentums ------------- {
p_mom               = rsi[1] < pmom and rsi > pmom and rsi > nmom and ta.change(ta.ema(close,5)) > 0
n_mom               = rsi < nmom and ta.change(ta.ema(close,5)) < 0
if p_mom
    positive:= true
    negative:= false

if n_mom
    positive:= false
    negative:= true

// ** ---> Confirmed State Tracking ------------- {
var bool confirmedBuyState  = false
var bool confirmedSellState = false

// ** ---> Signals ------------- {
pcondition  = positive and not positive[1]
ncondition2 = negative and not negative[1]

plotshape(showlabels ? pcondition : na, title="Buy Signal", style=shape.labelup, color=color.new(p, 60), location=location.belowbar, size=size.tiny, text="Buy?", textcolor=color.white)
plotshape(showlabels ? ncondition2 : na, title="Sell Signal", style=shape.labeldown, color=color.new(n, 60), location=location.abovebar, size=size.tiny, text="Sell?", textcolor=color.white)

// ** ---> Confirmation Logic ------------- {
var float buyConfirmLevel  = na
var float sellConfirmLevel = na
var int   buyBarIdx        = na
var int   sellBarIdx       = na

// On signal candle, record the level to break
if pcondition
    buyConfirmLevel  := high
    buyBarIdx        := bar_index
    sellConfirmLevel := na
    sellBarIdx       := na

if ncondition2
    sellConfirmLevel := low
    sellBarIdx       := bar_index
    buyConfirmLevel  := na
    buyBarIdx        := na

// Confirmed: close breaks level on a candle AFTER the signal, within N bars
buyConfirmed  = not na(buyBarIdx)  and bar_index > buyBarIdx  and bar_index <= buyBarIdx  + confirmBars and close > buyConfirmLevel
sellConfirmed = not na(sellBarIdx) and bar_index > sellBarIdx and bar_index <= sellBarIdx + confirmBars and close < sellConfirmLevel

// Reset once confirmed or window expires
if buyConfirmed or (not na(buyBarIdx) and bar_index > buyBarIdx + confirmBars)
    buyConfirmLevel := na
    buyBarIdx       := na

if sellConfirmed or (not na(sellBarIdx) and bar_index > sellBarIdx + confirmBars)
    sellConfirmLevel := na
    sellBarIdx       := na

// Update confirmed state for candle coloring
if buyConfirmed
    confirmedBuyState  := true
    confirmedSellState := false

if sellConfirmed
    confirmedSellState := true
    confirmedBuyState  := false

// ** ---> Candle Color Logic ------------- {
candleColor = confirmedBuyState ? p : confirmedSellState ? n : na

plotcandle(open, high, low, close,
     title        = "Colored Candles",
     color        = candleColor,
     wickcolor    = candleColor,
     bordercolor  = candleColor)

// ** ---> Confirmed Signal Plots ------------- {
plotshape(showlabels ? buyConfirmed  : na, title="Confirmed Buy",  style=shape.labelup,   color=p, location=location.belowbar, size=size.small, text="BUY",  textcolor=color.white)
plotshape(showlabels ? sellConfirmed : na, title="Confirmed Sell", style=shape.labeldown, color=n, location=location.abovebar, size=size.small, text="SELL", textcolor=color.white)

// Alerts //
alertcondition(pcondition,   "Buy Trend")
alertcondition(ncondition2,  "Sell Trend")
alertcondition(buyConfirmed,  "Confirmed Buy")
alertcondition(sellConfirmed, "Confirmed Sell")

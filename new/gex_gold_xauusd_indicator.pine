styEMStr = input.string("Dashed", "Style", options=["Solid", "Dashed", "Dotted"], group="Expected Move Style")

// Style converter
lineStyle(string s) =>
    s == "Dashed" ? line.style_dashed : s == "Dotted" ? line.style_dotted : line.style_solid

var string UPDATED = "2026-04-06 19:29"

// ===== GOLD GEX LEVELS (XAUUSD) =====
G_CW = input.float(5009.91, "Call Wall", group="GOLD XAUUSD Levels")
G_PW = input.float(4675.92, "Put Wall", group="GOLD XAUUSD Levels")

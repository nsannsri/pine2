    drawLevel(G_PG, clrPG, widPG, styPGStr, "Peak Gamma $" + str.tostring(G_PG, "#.##"), showPG)
    drawLevel(G_MP, clrMP, widMP, styMPStr, "Max Pain $" + str.tostring(G_MP, "#.##"), showMP)
    if barstate.islast
        int sBar = na(sessStart) ? bar_index - 50 : sessStart

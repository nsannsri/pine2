showOI = input.bool(true, "OI Buildup Lines", group="Display")
showHist = input.bool(true, "Level History Trail", group="Display")

// ===== LEVEL STYLE INPUTS =====
showCW = input.bool(true, "Call Wall", group="Call Wall Style")

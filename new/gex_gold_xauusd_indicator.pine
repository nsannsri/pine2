        label.new(sBar - 2, 4943.12, "$4943 (46.2K)", style=label.style_label_right, color=color.new(color.gray, 70), textcolor=color.white, size=size.small)
        line.new(sBar, 4876.32, bar_index + 10, 4876.32, color=color.new(#FFD700, 40), width=1, style=line.style_dotted)

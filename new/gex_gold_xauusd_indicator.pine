widCW = input.int(3, "Width", minval=1, maxval=5, group="Call Wall Style")
styCWStr = input.string("Solid", "Style", options=["Solid", "Dashed", "Dotted"], group="Call Wall Style")

showPW = input.bool(true, "Put Wall", group="Put Wall Style")

indicator("GOLD GEX Levels (XAUUSD)", overlay=true, max_lines_count=500, max_labels_count=500, max_boxes_count=500)

// ===== DISPLAY TOGGLES =====
showLevels = input.bool(true, "Show GEX Levels", group="Display")

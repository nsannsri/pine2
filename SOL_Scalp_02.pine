//@version=5
indicator("SOL Scalp 0.2 | VWAP + Supertrend + StochRSI + MACD B3/S3", overlay=true, max_labels_count=500, max_lines_count=500)

// ═══════════════════════════════════════════════════════════════
// INPUTS — SCALP
// ═══════════════════════════════════════════════════════════════

tp_points  = input.float(0.2,  "Take Profit (USD)",  step=0.05, group="Scalp Settings")
sl_points  = input.float(0.15, "Stop Loss (USD)",    step=0.05, group="Scalp Settings")
show_tpsl  = input.bool(true,  "Show TP/SL Lines",   group="Scalp Settings")
macd_filter = input.bool(true, "Require B3/S3 Confirmation", group="Scalp Settings")

st_factor  = input.float(2.0, "Supertrend Factor",  step=0.1, group="Supertrend")
st_atr     = input.int(7,     "Supertrend ATR",              group="Supertrend")

srsi_len   = input.int(8,  "Stoch RSI Length",   group="Stoch RSI")
srsi_k     = input.int(3,  "Stoch RSI K Smooth", group="Stoch RSI")
srsi_d     = input.int(3,  "Stoch RSI D Smooth", group="Stoch RSI")

vol_mult   = input.float(1.3, "Volume Spike x",  step=0.1, group="Volume")

// ═══════════════════════════════════════════════════════════════
// INPUTS — DOUBLE MACD HTF
// ═══════════════════════════════════════════════════════════════

tf             = input.timeframe("60",  "MACD Timeframe",   group="Double MACD HTF")
fast_length1   = input.int(21, "Long Fast",      group="Double MACD HTF")
slow_length1   = input.int(55, "Long Slow",      group="Double MACD HTF")
signal_length1 = input.int(9,  "Long Smoothing", group="Double MACD HTF")
fast_length2   = input.int(5,  "Short Fast",     group="Double MACD HTF")
slow_length2   = input.int(13, "Short Slow",     group="Double MACD HTF")
signal_length2 = input.int(6,  "Short Smoothing",group="Double MACD HTF")
show_b3        = input.bool(true, "Show B3 Labels", group="Double MACD HTF")
show_s3        = input.bool(true, "Show S3 Labels", group="Double MACD HTF")

// ═══════════════════════════════════════════════════════════════
// DOUBLE MACD HTF — B3 / S3 ONLY
// ═══════════════════════════════════════════════════════════════

f_macd_data() =>
    _macd1   = ta.ema(close, fast_length1) - ta.ema(close, slow_length1)
    _signal1 = ta.ema(_macd1, signal_length1)
    _hist1   = _macd1 - _signal1
    _macd2   = ta.ema(close, fast_length2) - ta.ema(close, slow_length2)
    _signal2 = ta.ema(_macd2, signal_length2)
    _hist2   = _macd2 - _signal2
    [_hist1, _hist2]

[hist1, hist2] = request.security(syminfo.tickerid, tf, f_macd_data(), lookahead=barmerge.lookahead_off)

// Color 0 = positive & growing | Color 3 = negative & falling
long_c0  = hist1 > 0 and hist1 > hist1[1]
long_c3  = hist1 < 0 and hist1 < hist1[1]
short_c0 = hist2 > 0 and hist2 > hist2[1]
short_c3 = hist2 < 0 and hist2 < hist2[1]

// B3 = both hists positive & growing | S3 = both hists negative & falling
b3_raw = long_c0 and short_c0
s3_raw = long_c3 and short_c3

// Fire only on first bar entering that state
b3_trigger = b3_raw and not (hist1[1] > 0 and hist1[1] > hist1[2] and hist2[1] > 0 and hist2[1] > hist2[2])
s3_trigger = s3_raw and not (hist1[1] < 0 and hist1[1] < hist1[2] and hist2[1] < 0 and hist2[1] < hist2[2])

// Alternating — no two B3s or two S3s in a row
var int last_b3s3 = 0
b3 = b3_trigger and last_b3s3 != 1
s3 = s3_trigger and last_b3s3 != -1
if b3
    last_b3s3 := 1
if s3
    last_b3s3 := -1

// Persistent state: are we in a B3 or S3 zone?
var bool in_b3_zone = false
var bool in_s3_zone = false
if b3
    in_b3_zone := true
    in_s3_zone := false
if s3
    in_s3_zone := true
    in_b3_zone := false

// ═══════════════════════════════════════════════════════════════
// VWAP
// ═══════════════════════════════════════════════════════════════

vwap       = ta.vwap(hlc3)
above_vwap = close > vwap
below_vwap = close < vwap

// ═══════════════════════════════════════════════════════════════
// SUPERTREND
// ═══════════════════════════════════════════════════════════════

[st_line, st_dir] = ta.supertrend(st_factor, st_atr)
st_bull = st_dir < 0
st_bear = st_dir > 0

// ═══════════════════════════════════════════════════════════════
// STOCH RSI
// ═══════════════════════════════════════════════════════════════

rsi_raw   = ta.rsi(close, srsi_len)
stoch_raw = ta.stoch(rsi_raw, rsi_raw, rsi_raw, srsi_len)
k         = ta.sma(stoch_raw, srsi_k)
d         = ta.sma(k, srsi_d)

k_cross_up   = ta.crossover(k, d)  and k < 50
k_cross_down = ta.crossunder(k, d) and k > 50

// ═══════════════════════════════════════════════════════════════
// VOLUME
// ═══════════════════════════════════════════════════════════════

vol_avg   = ta.sma(volume, 20)
vol_spike = volume > vol_avg * vol_mult

// ═══════════════════════════════════════════════════════════════
// ENTRY SIGNALS
// ═══════════════════════════════════════════════════════════════

scalp_long_base  = st_bull and above_vwap and k_cross_up   and vol_spike
scalp_short_base = st_bear and below_vwap and k_cross_down and vol_spike

// With MACD filter ON  → require B3/S3 zone active
// With MACD filter OFF → fire without MACD confirmation
long_signal  = macd_filter ? (scalp_long_base  and in_b3_zone) : scalp_long_base
short_signal = macd_filter ? (scalp_short_base and in_s3_zone) : scalp_short_base

// ═══════════════════════════════════════════════════════════════
// TP / SL LINES
// ═══════════════════════════════════════════════════════════════

if long_signal and show_tpsl
    tp = close + tp_points
    sl = close - sl_points
    line.new(bar_index, tp, bar_index + 10, tp, color=color.new(color.lime, 0), width=2, style=line.style_dashed)
    line.new(bar_index, sl, bar_index + 10, sl, color=color.new(color.red,  0), width=2, style=line.style_dashed)
    label.new(bar_index + 10, tp, "TP +" + str.tostring(tp_points), color=color.new(color.lime, 80), textcolor=color.lime, style=label.style_label_left, size=size.small)
    label.new(bar_index + 10, sl, "SL -" + str.tostring(sl_points), color=color.new(color.red,  80), textcolor=color.red,  style=label.style_label_left, size=size.small)

if short_signal and show_tpsl
    tp = close - tp_points
    sl = close + sl_points
    line.new(bar_index, tp, bar_index + 10, tp, color=color.new(color.lime, 0), width=2, style=line.style_dashed)
    line.new(bar_index, sl, bar_index + 10, sl, color=color.new(color.red,  0), width=2, style=line.style_dashed)
    label.new(bar_index + 10, tp, "TP -" + str.tostring(tp_points), color=color.new(color.lime, 80), textcolor=color.lime, style=label.style_label_left, size=size.small)
    label.new(bar_index + 10, sl, "SL +" + str.tostring(sl_points), color=color.new(color.red,  80), textcolor=color.red,  style=label.style_label_left, size=size.small)

// ═══════════════════════════════════════════════════════════════
// PLOTS
// ═══════════════════════════════════════════════════════════════

plot(vwap, "VWAP", color=color.new(color.blue, 0), linewidth=2)
plot(st_bull ? st_line : na, "ST Bull", color=color.new(color.lime, 0), linewidth=2, style=plot.style_linebr)
plot(st_bear ? st_line : na, "ST Bear", color=color.new(color.red,  0), linewidth=2, style=plot.style_linebr)

// Scalp entries
plotshape(long_signal,  "LONG",  location=location.belowbar, style=shape.triangleup,   size=size.normal, color=color.new(color.lime,   0), text="L",  textcolor=color.white)
plotshape(short_signal, "SHORT", location=location.abovebar, style=shape.triangledown, size=size.normal, color=color.new(color.red,    0), text="S",  textcolor=color.white)

// B3 / S3 labels
plotshape(show_b3 ? b3 : na, "B3", location=location.belowbar, style=shape.labelup,   color=color.new(color.purple, 0), textcolor=color.white, text="B3", size=size.normal)
plotshape(show_s3 ? s3 : na, "S3", location=location.abovebar, style=shape.labeldown, color=color.new(color.maroon, 0), textcolor=color.white, text="S3", size=size.normal)

bgcolor(above_vwap ? color.new(color.green, 96) : color.new(color.red, 96), title="VWAP Bias BG")

// ═══════════════════════════════════════════════════════════════
// STOCH RSI PANEL
// ═══════════════════════════════════════════════════════════════

plot(k, "K", color=color.new(color.blue,   0), display=display.pane)
plot(d, "D", color=color.new(color.orange, 0), display=display.pane)
hline(80, "OB",  color=color.new(color.red,   50), linestyle=hline.style_dashed)
hline(50, "Mid", color=color.new(color.gray,  50), linestyle=hline.style_dotted)
hline(20, "OS",  color=color.new(color.green, 50), linestyle=hline.style_dashed)

// ═══════════════════════════════════════════════════════════════
// ALERTS
// ═══════════════════════════════════════════════════════════════

alertcondition(long_signal,  "LONG  Signal", "SOL Scalp LONG  @ {{close}}")
alertcondition(short_signal, "SHORT Signal", "SOL Scalp SHORT @ {{close}}")
alertcondition(b3, "B3 — Both MACD Bullish", "MACD B3: Both histograms growing bullish")
alertcondition(s3, "S3 — Both MACD Bearish", "MACD S3: Both histograms growing bearish")

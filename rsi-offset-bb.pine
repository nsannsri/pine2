//@version=5
indicator("RSI Offset BB", shorttitle="RSI Offset BB", overlay=false)

// === INPUTS ===
rsiLen     = input.int(14, minval=1, title="RSI Length")
src        = input.source(close, title="Source")
bbLen      = input.int(20, minval=1, title="BB Length")
mult       = input.float(2.0, minval=0.1, title="BB Multiplier")
offsetBars = input.int(10, title="Offset (bars)")
upLine     = input.int(70, title="Overbought")
lowLine    = input.int(30, title="Oversold")

// === RSI ===
rsiVal = ta.rsi(src, rsiLen)

// === BB ON RSI ===
basis = ta.sma(rsiVal, bbLen)
dev   = mult * ta.stdev(rsiVal, bbLen)
upper = basis + dev
lower = basis - dev

// === OFFSET ===
basisOff = basis[offsetBars]
upperOff  = upper[offsetBars]
lowerOff  = lower[offsetBars]

// === PLOTS ===
plot(rsiVal,   color=color.aqua,   linewidth=2, title="RSI")
p1 = plot(upperOff,  color=color.green,  linewidth=1, title="Upper BB (Offset)")
p2 = plot(lowerOff,  color=color.red,    linewidth=1, title="Lower BB (Offset)")
plot(basisOff, color=color.orange, linewidth=1, title="Basis BB (Offset)")
fill(p1, p2, color=color.new(color.blue, 90), title="BB Fill")

hline(upLine,  "Overbought", color=color.red,   linestyle=hline.style_dashed)
hline(lowLine, "Oversold",   color=color.green, linestyle=hline.style_dashed)
hline(50,      "Mid",        color=color.gray,  linestyle=hline.style_dotted)

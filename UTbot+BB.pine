//@version=5
indicator("UT Bot + BB Trend Filter (Alternating Signals)", overlay=true)

// ═══════════════════════════════════
// INPUTS
// ═══════════════════════════════════

bb_length = input.int(55, "BB Length", group="Bollinger Bands")
bb_mult = input.float(1.0, "BB Std Dev", group="Bollinger Bands")

ut_sensitivity = input.float(2.0, "UT Sensitivity", group="UT Bot")
ut_atr_period = input.int(10, "UT ATR Period", group="UT Bot")

show_bb = input.bool(true, "Show BB", group="Display")
show_utbot = input.bool(true, "Show UT Line", group="Display")
show_pending = input.bool(true, "Show Pending Signals", group="Display")
signal_line_bars = input.int(5, "Signal Line Length (candles)", minval=1, maxval=50, group="Display")
signal_line_style = input.string("Dots", "Signal Line Style", options=["Line", "Dots"], group="Display")

// ═══════════════════════════════════
// BOLLINGER BANDS
// ═══════════════════════════════════

bb_basis = ta.sma(close, bb_length)
bb_dev = bb_mult * ta.stdev(close, bb_length)
bb_upper = bb_basis + bb_dev
bb_lower = bb_basis - bb_dev

long_breakout = close > bb_upper
short_breakout = close < bb_lower

L1 = ta.barssince(long_breakout)
S1 = ta.barssince(short_breakout)

bb_green = L1 < S1
bb_red = S1 < L1

// ═══════════════════════════════════
// UT BOT (RUNS INDEPENDENTLY)
// ═══════════════════════════════════

atr = ta.atr(ut_atr_period)
xATRTrailingStop = 0.0

iff_1 = close > nz(xATRTrailingStop[1], 0) ? close - (atr * ut_sensitivity) : close + (atr * ut_sensitivity)
iff_2 = close < nz(xATRTrailingStop[1], 0) and close[1] < nz(xATRTrailingStop[1], 0) ? math.min(nz(xATRTrailingStop[1]), close + (atr * ut_sensitivity)) : iff_1
xATRTrailingStop := close > nz(xATRTrailingStop[1], 0) and close[1] > nz(xATRTrailingStop[1], 0) ? math.max(nz(xATRTrailingStop[1]), close - (atr * ut_sensitivity)) : iff_2

pos = 0
iff_3 = close[1] > nz(xATRTrailingStop[1], 0) and close < nz(xATRTrailingStop[1], 0) ? -1 : nz(pos[1], 0)
pos := close[1] < nz(xATRTrailingStop[1], 0) and close > nz(xATRTrailingStop[1], 0) ? 1 : iff_3

// UT Bot raw signals
ut_buy_signal = pos == 1 and pos[1] == -1
ut_sell_signal = pos == -1 and pos[1] == 1

// ═══════════════════════════════════
// ALTERNATING SIGNAL LOGIC
// ═══════════════════════════════════

var bool pending_buy = false
var bool pending_sell = false
var int last_signal = 0  // 0 = none, 1 = buy, -1 = sell

// When UT Bot gives BUY signal
if ut_buy_signal
    if last_signal != 1  // Only allow buy if last signal wasn't a buy
        if bb_green
            // BB is already green → immediate confirmed buy
            pending_buy := false
            pending_sell := false
        else
            // BB is red → store as pending, wait for green
            pending_buy := true
            pending_sell := false

// When UT Bot gives SELL signal
if ut_sell_signal
    if last_signal != -1  // Only allow sell if last signal wasn't a sell
        if bb_red
            // BB is already red → immediate confirmed sell
            pending_sell := false
            pending_buy := false
        else
            // BB is green → store as pending, wait for red
            pending_sell := true
            pending_buy := false

// ═══════════════════════════════════
// CONFIRMED SIGNALS (WHEN CONDITIONS MATCH)
// ═══════════════════════════════════

// Confirmed BUY: UT gave buy signal AND BB is now green (and last signal wasn't buy)
confirmed_buy = last_signal != 1 and ((ut_buy_signal and bb_green) or (pending_buy and bb_green and not bb_green[1]))

// Confirmed SELL: UT gave sell signal AND BB is now red (and last signal wasn't sell)
confirmed_sell = last_signal != -1 and ((ut_sell_signal and bb_red) or (pending_sell and bb_red and not bb_red[1]))

// Update last signal and clear pending after confirmation
if confirmed_buy
    pending_buy := false
    last_signal := 1

if confirmed_sell
    pending_sell := false
    last_signal := -1

// ═══════════════════════════════════
// PLOTTING
// ═══════════════════════════════════

// Bollinger Bands
p_upper = plot(show_bb ? bb_upper : na, "BB Upper", color=color.green, linewidth=1)
p_lower = plot(show_bb ? bb_lower : na, "BB Lower", color=color.red, linewidth=1)

center_color = bb_green ? color.green : bb_red ? color.red : color.gray
p_basis = plot(show_bb ? bb_basis : na, "BB Center", color=center_color, linewidth=3)

fill(p_upper, p_basis, color=color.new(color.red, 85))
fill(p_lower, p_basis, color=color.new(color.green, 85))

// UT Bot line
plot(show_utbot ? xATRTrailingStop : na, "UT Bot", 
     color=pos == 1 ? color.green : color.red, 
     linewidth=2)

// Pending signals (small dots)
plotshape(show_pending and ut_buy_signal and not bb_green and last_signal != 1, "Pending Buy", 
          shape.circle, 
          location.belowbar, 
          color=color.yellow, 
          size=size.tiny,
          text="?")

plotshape(show_pending and ut_sell_signal and not bb_red and last_signal != -1, "Pending Sell", 
          shape.circle, 
          location.abovebar, 
          color=color.orange, 
          size=size.tiny,
          text="?")

// Confirmed signals (big triangles)
plotshape(confirmed_buy, "CONFIRMED BUY", 
          shape.triangleup, 
          location.belowbar, 
          color=color.lime, 
          size=size.normal)

plotshape(confirmed_sell, "CONFIRMED SELL", 
          shape.triangledown, 
          location.abovebar, 
          color=color.red, 
          size=size.normal)

// Labels
if confirmed_buy
    label.new(bar_index, low, "BUY", 
              color=color.green, 
              textcolor=color.white, 
              style=label.style_label_up, 
              size=size.normal)

if confirmed_sell
    label.new(bar_index, high, "SELL", 
              color=color.red, 
              textcolor=color.white, 
              style=label.style_label_down, 
              size=size.normal)

// Background
bgcolor(bb_green ? color.new(color.green, 95) : bb_red ? color.new(color.red, 95) : na)

// ═══════════════════════════════════
// DASHBOARD
// ═══════════════════════════════════

var table info = table.new(position.top_right, 2, 7)

if barstate.islast
    table.cell(info, 0, 0, "BB Trend", bgcolor=color.gray, text_color=color.white)
    table.cell(info, 1, 0, bb_green ? "GREEN" : "RED", 
               bgcolor=bb_green ? color.green : color.red, 
               text_color=color.white)
    
    table.cell(info, 0, 1, "UT Bot", bgcolor=color.gray, text_color=color.white)
    table.cell(info, 1, 1, pos == 1 ? "BULLISH" : "BEARISH", 
               bgcolor=pos == 1 ? color.green : color.red, 
               text_color=color.white)
    
    table.cell(info, 0, 2, "UT Signal", bgcolor=color.gray, text_color=color.white)
    ut_text = ut_buy_signal ? "BUY ↑" : ut_sell_signal ? "SELL ↓" : "---"
    table.cell(info, 1, 2, ut_text, bgcolor=color.new(color.gray, 70), text_color=color.white)
    
    table.cell(info, 0, 3, "Last Signal", bgcolor=color.gray, text_color=color.white)
    last_sig_text = last_signal == 1 ? "BUY" : last_signal == -1 ? "SELL" : "NONE"
    last_sig_color = last_signal == 1 ? color.green : last_signal == -1 ? color.red : color.gray
    table.cell(info, 1, 3, last_sig_text, 
               bgcolor=color.new(last_sig_color, 50), 
               text_color=color.white)
    
    table.cell(info, 0, 4, "Pending Buy", bgcolor=color.gray, text_color=color.white)
    table.cell(info, 1, 4, pending_buy ? "YES (waiting BB green)" : "NO", 
               bgcolor=pending_buy ? color.new(color.yellow, 50) : color.new(color.gray, 70), 
               text_color=color.white)
    
    table.cell(info, 0, 5, "Pending Sell", bgcolor=color.gray, text_color=color.white)
    table.cell(info, 1, 5, pending_sell ? "YES (waiting BB red)" : "NO", 
               bgcolor=pending_sell ? color.new(color.orange, 50) : color.new(color.gray, 70), 
               text_color=color.white)
    
    table.cell(info, 0, 6, "Price", bgcolor=color.gray, text_color=color.white)
    table.cell(info, 1, 6, str.tostring(close, format.mintick), 
               bgcolor=color.new(color.gray, 70), text_color=color.white)

// ═══════════════════════════════════
// SIGNAL LEVEL LINES
// ═══════════════════════════════════

var float _buy_lvl  = na
var int   _buy_bar  = na
var float _sell_lvl = na
var int   _sell_bar = na

if confirmed_buy
    _buy_lvl  := high
    _buy_bar  := bar_index

if confirmed_sell
    _sell_lvl := low
    _sell_bar := bar_index

_in_buy_zone  = not na(_buy_bar)  and bar_index >= _buy_bar  and bar_index <= _buy_bar  + signal_line_bars
_in_sell_zone = not na(_sell_bar) and bar_index >= _sell_bar and bar_index <= _sell_bar + signal_line_bars

_bval = _in_buy_zone  ? _buy_lvl  : na
_sval = _in_sell_zone ? _sell_lvl : na

plot(_bval, "Buy Level Line",  color=color.lime, linewidth=2,
     style=signal_line_style == "Dots" ? plot.style_circles : plot.style_linebr)
plot(_sval, "Sell Level Line", color=color.red,  linewidth=2,
     style=signal_line_style == "Dots" ? plot.style_circles : plot.style_linebr)

// ═══════════════════════════════════
// ALERTS
// ═══════════════════════════════════

alertcondition(confirmed_buy, "Confirmed Buy", "✅ CONFIRMED BUY - {{ticker}} @ {{close}}")
alertcondition(confirmed_sell, "Confirmed Sell", "✅ CONFIRMED SELL - {{ticker}} @ {{close}}")